# G-shell init file — sourced on startup
# Lines starting with # are ignored.
# Set GSHELLRC to a custom path to override this file.

# Welcome banner
fastfetch

# Aliases
alias ll='ls -lah'
alias la='ls -A'
alias g='git'
alias ..='cd ..'
alias ...='cd ../..'
alias cl='clear'

# Prompt
# Legacy PS1 (backslash escapes):
#   export PS1='\w \$ '
# Theme format (GS_PROMPT_FORMAT — {user} {host} {path} {git} {exit} {time} {root} {prompt} {newline}):
#   export GS_PROMPT_FORMAT='{user}@{host}:{path}{git}{exit} $ '
# Style segments with GS_STYLE_<NAME> env var (e.g., GS_STYLE_PATH="cyan bold"):
export PS1='\w \$ '

# History
export HISTFILE="$HOME/.g_shell_history"
