# G-shell init file — sourced on startup
# Lines starting with # are ignored.
# Set GSHELLRC to a custom path to override this file.

# Welcome banner
fastfetch

# Aliases
alias ll='ls -lah'
alias la='ls -A'
alias g='git'
alias ..='cd ..'
alias ...='cd ../..'
alias cl='clear'

# Prompt — default theme (set GS_PROMPT_FORMAT to customize)
# {user} {host} {path} {git} {exit} {time} {root} {prompt} {newline}
export GS_PROMPT_FORMAT='{user}@{host}:{path}{git}{exit} {prompt} '
export GS_STYLE_USER="green bold"
export GS_STYLE_HOST="green"
export GS_STYLE_PATH="cyan bold"
export GS_STYLE_GIT="yellow"
export GS_STYLE_EXIT="red"
export PS1='\w \$ '

# History
export HISTFILE="$HOME/.g_shell_history"
