# G-shell init file — sourced on startup
# Lines starting with # are ignored.
# Set GSHELLRC to a custom path to override this file.

# Welcome banner
echo "G-shell v1.1.3 — Type 'help' for commands."

# Aliases
alias ll='ls -lah'
alias la='ls -A'
alias g='git'
alias ..='cd ..'
alias ...='cd ../..'
alias cl='clear'

# Prompt
export PS1='\w \$ '

# History
export HISTFILE="$HOME/.g_shell_history"
